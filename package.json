{
  "name": "nextdream",
  "private": false,
  "version": "0.0.1",
  "type": "module",
  "workspaces": [
    "apps/api"
  ],
  "scripts": {
    "setup": "node scripts/setup.mjs",
    "dev": "vite",
    "dev:web": "vite",
    "dev:api": "npm run start:dev --workspace apps/api",
    "seed:local": "npm run seed:local --workspace apps/api",
    "build": "npm run build:web && npm run build:api",
    "build:web": "vite build",
    "build:api": "npm run build --workspace apps/api",
    "lint": "npm run lint:web && npm run lint:api",
    "lint:web": "eslint \"src/**/*.{ts,tsx}\" --max-warnings=0",
    "lint:api": "npm run lint --workspace apps/api",
    "typecheck": "npm run typecheck:web && npm run typecheck:api",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck:api": "npm run typecheck --workspace apps/api",
    "test": "npm run test:web && npm run test:api",
    "test:web": "vitest run",
    "test:api": "npm run test --workspace apps/api",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down -v",
    "docker:logs": "docker compose logs -f"
  },
  "dependencies": {
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.1",
    "@mui/icons-material": "7.3.5",
    "@mui/material": "7.3.5",
    "@popperjs/core": "2.11.8",
    "@radix-ui/react-accordion": "1.2.3",
    "@radix-ui/react-alert-dialog": "1.1.6",
    "@radix-ui/react-aspect-ratio": "1.1.2",
    "@radix-ui/react-avatar": "1.1.3",
    "@radix-ui/react-checkbox": "1.1.4",
    "@radix-ui/react-collapsible": "1.1.3",
    "@radix-ui/react-context-menu": "2.2.6",
    "@radix-ui/react-dialog": "1.1.6",
    "@radix-ui/react-dropdown-menu": "2.1.6",
    "@radix-ui/react-hover-card": "1.1.6",
    "@radix-ui/react-label": "2.1.2",
    "@radix-ui/react-menubar": "1.1.6",
    "@radix-ui/react-navigation-menu": "1.2.5",
    "@radix-ui/react-popover": "1.1.6",
    "@radix-ui/react-progress": "1.1.2",
    "@radix-ui/react-radio-group": "1.2.3",
    "@radix-ui/react-scroll-area": "1.2.3",
    "@radix-ui/react-select": "2.1.6",
    "@radix-ui/react-separator": "1.1.2",
    "@radix-ui/react-slider": "1.2.3",
    "@radix-ui/react-slot": "1.1.2",
    "@radix-ui/react-switch": "1.1.3",
    "@radix-ui/react-tabs": "1.1.3",
    "@radix-ui/react-toggle": "1.1.2",
    "@radix-ui/react-toggle-group": "1.1.2",
    "@radix-ui/react-tooltip": "1.1.8",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "cmdk": "1.1.1",
    "date-fns": "3.6.0",
    "embla-carousel-react": "8.6.0",
    "html2canvas": "^1.4.1",
    "input-otp": "1.4.2",
    "jspdf": "^4.2.1",
    "lucide-react": "0.487.0",
    "motion": "12.23.24",
    "next-themes": "0.4.6",
    "react": "18.3.1",
    "react-day-picker": "8.10.1",
    "react-dnd": "16.0.1",
    "react-dnd-html5-backend": "16.0.1",
    "react-dom": "18.3.1",
    "react-hook-form": "7.55.0",
    "react-popper": "2.3.0",
    "react-resizable-panels": "2.1.7",
    "react-responsive-masonry": "2.7.1",
    "react-router": "7.13.0",
    "react-slick": "0.31.0",
    "recharts": "2.15.2",
    "sonner": "2.0.3",
    "tailwind-merge": "3.2.0",
    "tw-animate-css": "1.3.8",
    "vaul": "1.1.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.23.0",
    "@tailwindcss/vite": "4.1.12",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.13.14",
    "@types/react": "^18.3.20",
    "@types/react-dom": "^18.3.6",
    "@vitejs/plugin-react": "4.7.0",
    "eslint": "^9.23.0",
    "globals": "^16.0.0",
    "jsdom": "^26.0.0",
    "tailwindcss": "4.1.12",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.28.0",
    "vitest": "^3.0.9",
    "vite": "6.3.5"
  },
  "pnpm": {
    "overrides": {
      "vite": "6.3.5"
    }
  }
}
