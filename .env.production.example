NODE_ENV=production
API_PORT=4000
APP_URL=https://nextdream.ong.br

# Frontend in production should call API through reverse proxy (/api)
VITE_API_URL=/api
VITE_SENTRY_DSN=<PROD_SENTRY_DSN_WEB>
VITE_SENTRY_TRACES_SAMPLE_RATE=0.15
VITE_SENTRY_RELEASE=<GIT_SHA_OR_RELEASE_TAG>
VITE_GA_MEASUREMENT_ID=G-P7HEP47P2M

# Comma-separated allowed origins for browser access
CORS_ORIGIN=https://nextdream.ong.br
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=120
# Production is expected to run behind a trusted reverse proxy.
TRUST_PROXY=true
# Required when TRUST_PROXY=true: comma-separated trusted proxy IPs/CIDRs.
PROXY_TRUSTED_IPS=127.0.0.1/32

# Production database is external (not provisioned by docker-compose.prod.yml)
# GitHub Secrets mapping:
#   PROD_DATABASE_URL -> DATABASE_URL
#   PROD_JWT_ACCESS_SECRET -> JWT_ACCESS_SECRET
#   PROD_JWT_REFRESH_SECRET -> JWT_REFRESH_SECRET
#   SENTRY_DSN_WEB -> SENTRY_DSN_WEB
#   SENTRY_DSN_API -> SENTRY_DSN
DATABASE_URL=postgresql://postgres.<SUPABASE_PROJECT_REF>:<YOUR_SUPABASE_PASSWORD>@aws-1-sa-east-1.pooler.supabase.com:6543/postgres?sslmode=require
JWT_ACCESS_SECRET=<PROD_JWT_ACCESS_SECRET>
JWT_REFRESH_SECRET=<PROD_JWT_REFRESH_SECRET>
SENTRY_DSN=<PROD_SENTRY_DSN_API>
SENTRY_DSN_WEB=<PROD_SENTRY_DSN_WEB>
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.15
SENTRY_RELEASE=<GIT_SHA_OR_RELEASE_TAG>
AUTH_COOKIE_DOMAIN=nextdream.ong.br
AUTH_COOKIE_SECURE=true
SENTRY_EMIT_STARTUP_TEST_LOG=false
